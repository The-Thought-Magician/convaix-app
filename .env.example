CONVAIX_DB=sqlite:///~/.convaix/convaix.db
# CONVAIX_DB=postgresql://convaix:convaix@localhost/convaix

CONVAIX_EMBEDDER=auto
# CONVAIX_EMBEDDER=sentence_tf   # cross-platform (default on non-Apple)
# CONVAIX_EMBEDDER=mlx           # Apple Silicon only, faster

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# For RAG fallback if Ollama is not installed:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
